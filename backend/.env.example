# Server
PORT=5000
NODE_ENV=development

# CORS — set to your frontend domain in production
CORS_ORIGIN=http://localhost:5000

# ─── MySQL Database ────────────────────────────────────────────────────────────
# MySQL 8.0 must be running locally (it's already installed on this machine).
# The database "portfolio_db" will be auto-created on first run.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_root_password_here
MYSQL_DATABASE=portfolio_db

# Email (optional - for contact form notifications)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your.email@gmail.com
# EMAIL_PASS=your_app_password
# EMAIL_TO=your.email@gmail.com
